# Copy to .env (for docker compose) or .env.local (for npm run dev).

# Required — auth secret for the UI, API, and MCP endpoint.
# Generate one: openssl rand -hex 32
KYBASE_SECRET=

# ── docker compose ──────────────────────────────────────────
# The database is only reachable inside the compose network, but set your
# own password anyway: openssl rand -hex 16
POSTGRES_PASSWORD=change-me
KYBASE_PORT=3000
# Prebuilt image tag from ghcr.io/kyrzin/kybase — pin a release (e.g. v1.0.0)
# instead of tracking main.
KYBASE_TAG=latest

# ── local dev (npm run dev) ─────────────────────────────────
# Direct Postgres connection; in compose it is derived automatically.
# DATABASE_URL=postgres://kybase:kybase@localhost:5432/kybase

# ── embeddings ──────────────────────────────────────────────
EMBEDDING_PROVIDER=ollama
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=embeddinggemma

# Google alternative (free tier)
# EMBEDDING_PROVIDER=google
# GOOGLE_API_KEY=
# GOOGLE_MODEL=text-embedding-004

# OpenAI alternative
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=
